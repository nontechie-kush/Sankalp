# Sankalp — Environment Variables
# Copy this to .env and fill in your values

PORT=3000
NODE_ENV=development

# Browser Supabase client.
# These are publishable frontend values; RLS/RPC policies protect data.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# Phone OTP
# Configure Supabase Auth > Phone provider with Twilio Verify.
# This app calls Supabase Auth; Twilio credentials stay inside Supabase.

# Payments — Razorpay
# Razorpay secrets are used by Supabase Edge Functions, not this Express server.
# Set these with `supabase secrets set`:
# RAZORPAY_KEY_ID=your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret

# WhatsApp Business API (future)
# WHATSAPP_API_KEY=your_key_here
# WHATSAPP_PHONE_ID=your_phone_id

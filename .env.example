# Sankalp — Environment Variables
# Copy this to .env and fill in your values

PORT=3000
NODE_ENV=development

# Database — Supabase (use service role key on server, never expose in frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Phone OTP
# Configure Supabase Auth > Phone provider with Twilio Verify.
# This app calls Supabase Auth; Twilio credentials stay inside Supabase.

# Payments — Razorpay (Step 4)
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# WhatsApp Business API (future)
# WHATSAPP_API_KEY=your_key_here
# WHATSAPP_PHONE_ID=your_phone_id
